{
  "expo": {
    "name": "Picture-Aliver",
    "slug": "picture-aliver",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.picturealiver.mobile"
    },
    "android": {
      "package": "com.picturealiver.mobile",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-image-picker",
      "expo-av",
      "expo-file-system"
    ],
    "extra": {
      "eas": {
        "projectId": "picture-aliver-mobile"
      }
    }
  }
}